import React, { useState, useEffect } from 'react';
import { StyleSheet, Text, View, TouchableOpacity, Image } from 'react-native';

export default function App() {
  const [seconds, setSeconds] = useState(0);
  const [isRunning, setIsRunning] = useState(false);
  const [intervalId, setIntervalId] = useState(null);
  const [lastTime, setLastTime] = useState(0);

  useEffect(() => {
    if (isRunning) {
      const id = setInterval(() => {
        setSeconds((prevSeconds) => prevSeconds + 0.1);
      }, 100);
      setIntervalId(id);
    } else if (intervalId) {
      clearInterval(intervalId);
    }
    return () => clearInterval(intervalId);
  }, [isRunning]);

  const startStopTimer = () => {
    setIsRunning(!isRunning);
  };

  const resetTimer = () => {
    setLastTime(seconds.toFixed(1));
    setIsRunning(false);
    setSeconds(0);
  };

  return (
    <View style={styles.container}>
      <View style={styles.imageContainer}>
        <Image
          source={require('./assets/cronometro.png')}
          style={styles.image}
        />
        <Text style={styles.timer}>{seconds.toFixed(1)}</Text>
      </View>
      
      <View style={styles.buttonContainer}>
        <TouchableOpacity style={styles.button} onPress={startStopTimer}>
          <Text style={styles.buttonText}>{isRunning ? 'PAUSAR' : 'VAI'}</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.button} onPress={resetTimer}>
          <Text style={styles.buttonText}>LIMPAR</Text>
        </TouchableOpacity>
      </View>
      <Text style={styles.lastTime}>Último tempo: {lastTime}s</Text>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    justifyContent: 'center',
    alignItems: 'center',
    backgroundColor: '#1E90FF',
  },
  imageContainer: {
    justifyContent: 'center',
    alignItems: 'center',
    marginBottom: 30,
  },
  image: {
    width: 178, 
    height: 200, 
    justifyContent: 'center',
    alignItems: 'center',
    position: 'relative', 
  },
  timer: {
    fontSize: 60,
    color: '#fff', 
    position: 'absolute', 
    top: '50%', 
    left: '50%',
    transform: [{ translateX: -40 }, { translateY: -30 }],
  },
  buttonContainer: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    width: 220,
  },
  button: {
    backgroundColor: 'white',
    paddingVertical: 10,
    paddingHorizontal: 20,
    borderRadius: 30,
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.2,
    shadowRadius: 5,
  },
  buttonText: {
    fontSize: 18,
    color: '#1E90FF',
  },
  lastTime: {
    fontSize: 18,
    color: '#fff',
    marginTop: 20,
  },
});
